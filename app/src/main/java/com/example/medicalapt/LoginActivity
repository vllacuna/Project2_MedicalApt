package com.example.medicalapt;

import android.os.Bundle;
import android.view.View;

import androidx.appcompat.app.AppCompatActivity;

import com.example.medicalapt.database.medicalaptRepository;
import com.example.medicalapt.databinding.ActivityLoginBinding;
public class LoginActivity extends AppCompatActivity {
    private com.example.medicalapt.ActivityLoginBinding binding;
    private medicalaptRepository repository;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        binding= ActivityLoginBinding.inflate(getLayoutInflater());
        setContentView(binding.getRoot());
        repository =medicalaptRepository.getRepository(getApplication());

        binding.loginButton.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View view) {
                verifyUser();

            }
        });
    }


}
